{
    "name": "awen",
    "version-string": "2026.3.20",
    "port-version": 1,
    "description": "A modern C++ game engine for creation and exploration.",
    "homepage": "https://github.com/funnansoftwarellc/awen",
    "dependencies": [
        "gtest",
        "sdl3",
        {
            "name": "skia",
            "default-features": false,
            "features": [
                "dng",
                "graphite",
                "harfbuzz",
                "icu",
                "jpeg",
                "png",
                "vulkan",
                "webp"
            ]
        },
        {
            "name": "skia",
            "default-features": false,
            "features": [
                "fontconfig",
                "freetype"
            ],
            "platform": "linux"
        },
        {
            "name": "skia",
            "default-features": false,
            "features": [
                "metal"
            ],
            "platform": "osx | ios"
        }
    ]
}