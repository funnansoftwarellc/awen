{
    "editor.formatOnSave": true,
    "cmake.configureOnOpen": false,
    "cmake.configureOnEdit": false,
    "files.associations": {
        "*.ixx": "cpp",
        "*.cppm": "cpp"
    },
    "clangd.path": "clangd",
    "clangd.arguments": [
        "--compile-commands-dir=${command:cmake.buildDirectory}"
    ]
}