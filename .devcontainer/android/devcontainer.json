{
    "name": "awen - android",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "runArgs": [
        "--privileged",
        "--device",
        "/dev/kvm",
        "--volume",
        "/dev/bus/usb:/dev/bus/usb"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cmake-tools",
                "GitHub.vscode-pull-request-github",
                "github.vscode-github-actions",
                "mhutchie.git-graph"
            ]
        }
    },
    "postCreateCommand": "${containerWorkspaceFolder}/vcpkg/bootstrap-vcpkg.sh -disableMetrics && curl -fsSL -o ${containerWorkspaceFolder}/android/gradle/wrapper/gradle-wrapper.jar https://raw.githubusercontent.com/gradle/gradle/v8.11.1/gradle/wrapper/gradle-wrapper.jar && printf 'sdk.dir=/opt/android/sdk\nndk.dir=/opt/android/ndk/android-ndk-r29\n' > ${containerWorkspaceFolder}/android/local.properties"
}