{
    "version": 7,
    "include": [
        "android.json",
        "arm64-android.json",
        "binarydir.json",
        "debug.json",
        "ninja.json",
        "release.json",
        "vcpkg.json"
    ],
    "configurePresets": [
        {
            "name": "arm64-android-clang-debug",
            "inherits": [
                "arm64-android",
                "android",
                "binarydir",
                "debug",
                "ninja",
                "vcpkg"
            ]
        },
        {
            "name": "arm64-android-clang-release",
            "inherits": [
                "arm64-android",
                "android",
                "binarydir",
                "release",
                "ninja",
                "vcpkg"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "arm64-android-clang-debug",
            "configurePreset": "arm64-android-clang-debug"
        },
        {
            "name": "arm64-android-clang-release",
            "configurePreset": "arm64-android-clang-release"
        }
    ]
