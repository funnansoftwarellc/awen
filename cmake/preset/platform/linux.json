{
    "version": 7,
    "include": [
        "../binarydir.json",
        "../compiler/clang.json",
        "../debug.json",
        "../compiler/gcc.json",
        "../ninja.json",
        "../release.json",
        "../vcpkg.json",
        "../host/x64-linux.json",
        "../target/x64-linux.json"
    ],
    "configurePresets": [
        {
            "name": "x64-linux-gcc-debug",
            "inherits": [
                "binarydir",
                "debug",
                "compiler-gcc",
                "ninja",
                "vcpkg",
                "host-x64-linux",
                "target-x64-linux"
            ]
        },
        {
            "name": "x64-linux-gcc-release",
            "inherits": [
                "binarydir",
                "release",
                "compiler-gcc",
                "ninja",
                "vcpkg",
                "host-x64-linux",
                "target-x64-linux"
            ]
        },
        {
            "name": "x64-linux-clang-debug",
            "inherits": [
                "binarydir",
                "debug",
                "compiler-clang",
                "ninja",
                "vcpkg",
                "host-x64-linux",
                "target-x64-linux"
            ]
        },
        {
            "name": "x64-linux-clang-release",
            "inherits": [
                "binarydir",
                "release",
                "compiler-clang",
                "ninja",
                "vcpkg",
                "host-x64-linux",
                "target-x64-linux"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "x64-linux-gcc-debug",
            "configurePreset": "x64-linux-gcc-debug"
        },
        {
            "name": "x64-linux-gcc-release",
            "configurePreset": "x64-linux-gcc-release"
        },
        {
            "name": "x64-linux-clang-debug",
            "configurePreset": "x64-linux-clang-debug"
        },
        {
            "name": "x64-linux-clang-release",
            "configurePreset": "x64-linux-clang-release"
        }
    ],
    "testPresets": [
        {
            "name": "x64-linux-gcc-debug",
            "configurePreset": "x64-linux-gcc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "x64-linux-gcc-release",
            "configurePreset": "x64-linux-gcc-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "x64-linux-clang-debug",
            "configurePreset": "x64-linux-clang-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "x64-linux-clang-release",
            "configurePreset": "x64-linux-clang-release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}