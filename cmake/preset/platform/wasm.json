{
    "version": 7,
    "include": [
        "../binarydir.json",
        "../debug.json",
        "../compiler/emcc.json",
        "../ninja.json",
        "../release.json",
        "../vcpkg.json",
        "../target/wasm32-emscripten.json"
    ],
    "configurePresets": [
        {
            "name": "wasm32-emscripten-debug",
            "inherits": [
                "compiler-emscripten",
                "binarydir",
                "debug",
                "ninja",
                "vcpkg",
                "target-wasm32-emscripten"
            ]
        },
        {
            "name": "wasm32-emscripten-release",
            "inherits": [
                "compiler-emscripten",
                "binarydir",
                "release",
                "ninja",
                "vcpkg",
                "target-wasm32-emscripten"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "wasm32-emscripten-debug",
            "configurePreset": "wasm32-emscripten-debug"
        },
        {
            "name": "wasm32-emscripten-release",
            "configurePreset": "wasm32-emscripten-release"
        }
    ]
}