{
    "version": 7,
    "include": [
        "../binarydir.json",
        "../compiler/clang.json",
        "../debug.json",
        "../ninja.json",
        "../release.json",
        "../vcpkg.json",
        "../host/arm64-osx.json",
        "../target/arm64-osx.json"
    ],
    "configurePresets": [
        {
            "name": "arm64-osx-clang-debug",
            "inherits": [
                "binarydir",
                "debug",
                "compiler-clang",
                "ninja",
                "vcpkg",
                "host-arm64-osx",
                "target-arm64-osx"
            ]
        },
        {
            "name": "arm64-osx-clang-release",
            "inherits": [
                "binarydir",
                "release",
                "compiler-clang",
                "ninja",
                "vcpkg",
                "host-arm64-osx",
                "target-arm64-osx"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "arm64-osx-clang-debug",
            "configurePreset": "arm64-osx-clang-debug"
        },
        {
            "name": "arm64-osx-clang-release",
            "configurePreset": "arm64-osx-clang-release"
        }
    ],
    "testPresets": [
        {
            "name": "arm64-osx-clang-debug",
            "configurePreset": "arm64-osx-clang-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "arm64-osx-clang-release",
            "configurePreset": "arm64-osx-clang-release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}