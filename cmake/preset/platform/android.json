        {
            "name": "x64-linux-clang-arm64-android-release",
            "inherits": [
                "compiler-android-ndk",
                "binarydir",
                "release",
                "ninja",
                "host-x64-linux",
                "target-arm64-android"
            ]
        },
        {
            "name": "x64-windows-clang-arm64-android-debug",
            "inherits": [
                "compiler-android-ndk",
                "binarydir",
                "debug",
                "ninja",
                "host-x64-windows",
                "target-arm64-android"
            ]
        },
        {
            "name": "x64-windows-clang-arm64-android-release",
