{
    "version": 7,
    "include": [
        "../compiler/android-ndk.json",
        "../binarydir.json",
        "../debug.json",
        "../ninja.json",
        "../release.json",
        "../vcpkg.json",
        "../host/x64-linux.json",
        "../target/arm64-android.json"
    ],
    "configurePresets": [
        {
            "name": "arm64-android-clang-debug",
