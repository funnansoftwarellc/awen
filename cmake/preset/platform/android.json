{
    "version": 7,
    "include": [
        "../compiler/android-ndk.json",
        "../binarydir.json",
        "../debug.json",
        "../ninja.json",
        "../release.json",
        "../host/x64-linux.json",
        "../host/x64-windows.json",
        "../target/arm64-android.json"
    ],
    "configurePresets": [
        {
            "name": "x64-linux-clang-arm64-android-debug",
            "inherits": [
                "compiler-android-ndk",
                "binarydir",
                "debug",
                "ninja",
                "host-x64-linux",
                "target-arm64-android"
            ]
