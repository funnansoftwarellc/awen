{
    "version": 7,
    "include": [
        "../binarydir.json",
        "../debug.json",
        "../compiler/mingw-gcc.json",
        "../compiler/msvc.json",
        "../ninja.json",
        "../release.json",
        "../vcpkg.json",
        "../host/x64-windows.json",
        "../target/x64-windows.json",
        "../target/x64-mingw.json",
        "../compiler/visualstudio.json"
    ],
    "configurePresets": [
        {
            "name": "x64-windows-visualstudio",
            "inherits": [
                "binarydir",
                "compiler-visualstudio",
                "vcpkg",
                "host-x64-windows"
            ]
        },
        {
            "name": "x64-windows-msvc-debug",
            "inherits": [
                "binarydir",
                "debug",
                "compiler-msvc",
                "ninja",
                "vcpkg",
                "host-x64-windows",
                "target-x64-windows"
            ]
        },
        {
            "name": "x64-windows-msvc-release",
            "inherits": [
                "binarydir",
                "release",
                "compiler-msvc",
                "ninja",
                "vcpkg",
                "host-x64-windows",
                "target-x64-windows"
            ]
        },
        {
            "name": "x64-windows-mingw-gcc-debug",
            "inherits": [
                "binarydir",
                "debug",
                "compiler-mingw-gcc",
                "ninja",
                "vcpkg",
                "host-x64-windows",
                "target-x64-mingw"
            ]
        },
        {
            "name": "x64-windows-mingw-gcc-release",
            "inherits": [
                "binarydir",
                "release",
                "compiler-mingw-gcc",
                "ninja",
                "vcpkg",
                "host-x64-windows",
                "target-x64-mingw"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "x64-windows-visualstudio",
            "configurePreset": "x64-windows-visualstudio"
        },
        {
            "name": "x64-windows-msvc-debug",
            "configurePreset": "x64-windows-msvc-debug"
        },
        {
            "name": "x64-windows-msvc-release",
            "configurePreset": "x64-windows-msvc-release"
        },
        {
            "name": "x64-windows-mingw-gcc-debug",
            "configurePreset": "x64-windows-mingw-gcc-debug"
        },
        {
            "name": "x64-windows-mingw-gcc-release",
            "configurePreset": "x64-windows-mingw-gcc-release"
        }
    ],
    "testPresets": [
        {
            "name": "x64-windows-msvc-debug",
            "configurePreset": "x64-windows-msvc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "x64-windows-msvc-release",
            "configurePreset": "x64-windows-msvc-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "x64-windows-mingw-gcc-debug",
            "configurePreset": "x64-windows-mingw-gcc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "x64-windows-mingw-gcc-release",
            "configurePreset": "x64-windows-mingw-gcc-release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}