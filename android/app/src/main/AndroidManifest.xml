<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.funnansoftware.awen">

    <application
        android:label="@string/app_name"
        android:hasCode="false">

        <!--
            NativeActivity hosts the entire app natively. No Java/Kotlin Activity
            subclass is required. android:hasCode="false" tells the runtime there
            are no Dalvik/ART class files to load.
        -->
        <activity
            android:name="android.app.NativeActivity"
            android:label="@string/app_name"
            android:exported="true"
            android:configChanges="orientation|keyboardHidden|screenLayout|screenSize|smallestScreenSize">

            <!--
                The value must match the CMake target name (i.e. the library is
                libawen.so, so the value is "awen").
            -->
            <meta-data
                android:name="android.app.lib_name"
                android:value="awen" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
